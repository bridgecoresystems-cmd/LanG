{
  "name": "language-school-monorepo",
  "version": "1.0.5",
  "description": "Monorepo for Language School project by BridgeCore SYSTEMS",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd packages/backend && bun run dev",
    "dev:frontend": "cd packages/frontend && bun run dev",
    "dev:mobile": "cd packages/mobile && bun run dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd packages/backend && bun run build",
    "build:frontend": "cd packages/frontend && bun run build",
    "build:mobile": "cd packages/mobile && bun run build",
    "start": "bun run start:backend",
    "start:backend": "cd packages/backend && bun run src/index.ts",
    "start:frontend": "cd packages/frontend && bun run preview",
    "db:generate": "cd packages/backend && bun run db:generate",
    "db:migrate": "cd packages/backend && bun run db:migrate",
    "db:push": "cd packages/backend && bun run db:push",
    "db:studio": "cd packages/backend && bun run db:studio",
    "seed": "cd packages/backend && bun run seed.ts",
    "install:all": "bun install && cd packages/backend && bun install && cd ../frontend && bun install && cd ../mobile && bun install",
    "typecheck": "cd packages/backend && bun run typecheck && cd ../frontend && bun run typecheck",
    "lint": "cd packages/frontend && bun run lint",
    "format": "prettier --write \"packages/**/*.{ts,js,vue,json}\"",
    "clean": "rm -rf packages/backend/node_modules packages/frontend/node_modules packages/mobile/node_modules node_modules"
  },
  "keywords": [
    "language-school",
    "erp",
    "bridgecore",
    "elysia",
    "nuxt",
    "bun",
    "drizzle",
    "lucia"
  ],
  "author": "Batyr Akmuradov <info@bridgecore.tech> (https://bridgecore.tech)",
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1"
  }
}
