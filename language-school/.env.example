# ===========================================
# BridgeCore SYSTEMS - Language School
# Переменные окружения
# ===========================================
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ===========================================
# 🔷 BACKEND (packages/backend/)
# ===========================================

# PostgreSQL Database
# Формат: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/language_school

# Порт сервера
PORT=8000

# Режим работы (development/production)
NODE_ENV=development

# Сессии Lucia (опционально, по умолчанию работает)
# SESSION_SECRET=your-secret-key-here

# ===========================================
# 🔷 FRONTEND (packages/frontend/)
# ===========================================

# URL backend API
API_URL=http://localhost:8000

# Публичный базовый URL API (используется в браузере)
NUXT_PUBLIC_API_BASE=http://localhost:8000

# Порт frontend dev сервера (по умолчанию 3000)
PORT=3000

# Режим работы (development/production)
NODE_ENV=development

# ===========================================
# 🔷 PRODUCTION (для развёртывания)
# ===========================================

# Домен backend (в production)
# API_URL=https://api.bridgecore.tech

# Домен frontend (в production)
# NUXT_PUBLIC_API_BASE=https://api.bridgecore.tech

# База данных (production)
# DATABASE_URL=postgresql://user:password@db-host:5432/language_school

# ===========================================
# 🔷 ОПЦИОНАЛЬНО
# ===========================================

# Логирование (debug mode)
# DEBUG=true

# Максимальный размер загружаемых файлов (в байтах)
# MAX_FILE_SIZE=10485760

# WebSocket порт (если отличается от основного)
# WS_PORT=8000

# Redis (для кэширования, если понадобится)
# REDIS_URL=redis://localhost:6379

# Email (для уведомлений, если понадобится)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# ===========================================
# 🔷 БЕЗОПАСНОСТЬ
# ===========================================

# ⚠️ ВАЖНО: Никогда не коммитьте файл .env в git!
# ⚠️ Файл .env должен быть в .gitignore

# Для генерации секретных ключей используйте:
# bun run -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
